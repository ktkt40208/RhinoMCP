<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>12</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>Acp</RootNamespace>
    <AssemblyName>Acp</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- Generated XML doc-comments are best-effort one-liners; don't fail the build over them. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <!-- The codegen tool is its own project; keep its sources out of the library. -->
  <ItemGroup>
    <Compile Remove="codegen/**/*.cs" />
  </ItemGroup>

  <!-- ACP wire types are generated from schema/*.json. Run the codegen automatically at build so
       `dotnet build` is self-contained (no manual `dotnet run` step). The generated files stay
       gitignored build artifacts. Two targets because the SDK globs Compile items during evaluation,
       before any target runs: a clean build has no generated files at glob time, so the default glob
       is told to skip them and IncludeAcpGeneratedCode re-adds them after generation, before compile. -->
  <PropertyGroup>
    <AcpGeneratedDir>$(MSBuildThisFileDirectory)src/Generated</AcpGeneratedDir>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="src/Generated/**/*.cs" />
  </ItemGroup>

  <!-- Incremental: only regenerates when the schema or the generator changes (or when the outputs
       are missing, e.g. a clean checkout / wiped folder). -->
  <Target Name="GenerateAcpCode"
          BeforeTargets="BeforeCompile;CoreCompile"
          Inputs="$(MSBuildThisFileDirectory)schema/schema.json;$(MSBuildThisFileDirectory)schema/meta.json;$(MSBuildThisFileDirectory)codegen/Program.cs"
          Outputs="$(AcpGeneratedDir)/Enums.g.cs;$(AcpGeneratedDir)/Unions.g.cs;$(AcpGeneratedDir)/Types.g.cs;$(AcpGeneratedDir)/Methods.g.cs">
    <Message Importance="high" Text="Acp: regenerating wire types from schema/*.json" />
    <Exec WorkingDirectory="$(MSBuildThisFileDirectory)"
          Command="dotnet run --project codegen/Acp.Codegen.csproj --configuration Debug --verbosity quiet -- schema/schema.json schema/meta.json src/Generated" />
  </Target>

  <!-- Always runs (no Inputs/Outputs) so the generated files are in @(Compile) even when generation
       was skipped as up-to-date; depends on GenerateAcpCode so a clean build generates first. -->
  <Target Name="IncludeAcpGeneratedCode"
          DependsOnTargets="GenerateAcpCode"
          BeforeTargets="BeforeCompile;CoreCompile">
    <ItemGroup>
      <Compile Include="$(AcpGeneratedDir)/*.g.cs" />
    </ItemGroup>
  </Target>

</Project>
